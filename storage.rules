rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 피드 미디어 — 누구나 보기, 본인 폴더에만 업로드(50MB 제한).
    //  04-13: write 에 크기 검사(request.resource.size)가 걸려 있어 '삭제' 시(request.resource=null)
    //   조건이 실패해 소유자도 자기 파일을 못 지웠다 → 등록 실패 보상 삭제 불가.
    //   create/update(크기 검사 유지)와 delete(본인만)를 분리한다. read 정책·경로·소유권은 그대로.
    match /feed/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // 프로필 사진(아바타) — 누구나 보기, 본인만 업로드(10MB 제한)
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
