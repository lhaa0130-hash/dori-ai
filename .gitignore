# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# 빌드 중 .next 삭제 실패 시 리네임되는 스테일 캐시(윈도우 파일락 회피) — 100MB+ 정크, 절대 커밋 금지
.next-stale-*/
.next-build-stale-*/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# open-next (Cloudflare Pages build artifacts)
.open-next/
dori-ai-vite/
antigravity-awesome-skills/
install-companion

# 동물도감 SNS 카드 렌더(웹사이트 미사용·대용량 PNG) — 깃 추적 제외
public/cards/animal/
out/cards/animal/
build_galaxy.log

# 빌드·배포 동시실행 방지 락(deploy.js) — 커밋 금지
.deploy.lock

# firebase emulator 실행 산출물
firestore-debug.log
ui-debug.log
database-debug.log
firebase-debug.log
.firebase/
