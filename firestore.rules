rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자(이메일 기준) 판별 — 솜사탕 지급/프리미엄 설정 등 타회원 문서 쓰기 허용
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'lhaa0130@gmail.com';
    }

    // ⚠️ 비공개 계정 정보(이메일·성별·연령대·provider) — 본인과 관리자만 읽고 쓴다.
    //    users/{uid}는 공개 읽기(read:if true)라 이메일 등 PII를 여기 두면 안 된다.
    //    (01-A단계: 이메일 공개 노출 차단 — PII를 users 밖 이 컬렉션으로 분리)
    match /userPrivate/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 회원 — 본인 또는 관리자만 수정 (공개 읽기 O, 단 PII는 userPrivate로 분리)
    // ⚠️ 공개 문서라 PII(email·gender·ageGroup·provider)를 다시 쓰지 못하게 차단(회귀 방지).
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin())
        && !request.resource.data.keys().hasAny(['email', 'gender', 'ageGroup', 'provider']);

      // 친구 목록 — 본인 또는 '자신을 추가하는' 상대(수락 시 양방향)
      match /friends/{friendUid} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid);
      }
      // 친구 범위(그룹) — 본인만 (비공개 설정)
      match /groups/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // 팔로워 목록 — 누구나 읽기, '나를 팔로워로 추가하는' 본인(=followerUid)만 작성/삭제
      match /followers/{followerUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == followerUid;
      }
      // 팔로잉 목록 — 누구나 읽기, 주인만 작성/삭제
      match /following/{followeeUid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      // 북마크(저장) — 본인만 (비공개)
      match /bookmarks/{postId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 친구 요청 — 받는 사람이 읽기, 보내는 사람이 생성, 둘 다 삭제(수락/거절/취소)
    match /friend_requests/{toUid}/incoming/{fromUid} {
      allow read:   if request.auth != null && request.auth.uid == toUid;
      allow create: if request.auth != null && request.auth.uid == fromUid;
      allow delete: if request.auth != null && (request.auth.uid == toUid || request.auth.uid == fromUid);
    }

    // 방문자 집계 + 애드센스
    match /analytics/{docId}       { allow read, write: if true; }
    match /analyticsDaily/{dateId} { allow read, write: if true; }

    // 대시보드 통계(GA4·애드센스 수입) — 관리자만 읽기, 쓰기는 서버 SA만(규칙 우회)
    match /dashboardStats/{docId}  { allow read: if isAdmin(); allow write: if false; }

    // 일로 일일 사용량
    match /illoQuota/{docId}       { allow read, write: if true; }

    // 미니게임 명예의 전당(랭킹) — 모든 게임 커버
    match /leaderboards/{game}/scores/{uid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 미니게임 클라우드 세이브(진행도) — 본인 것만 읽기/쓰기 (보스 클릭커 등)
    match /gameSaves/{game}/players/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 프로젝트 개인 저장(아크일로 설계·워크일로 작업·트레이더일로 설정 등) — 본인 것만
    match /projectSaves/{project}/users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 심리테스트 결과 이력(완료 날짜·점수) — 민감정보라 본인만 읽기/쓰기 (비공개)
    match /psychLogs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 인사이트 글 좋아요 — 카운터는 로그인 시 증감, '좋아요한 사람'은 본인만 기록
    match /articleLikes/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
      match /likers/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 인사이트 글 댓글 — 누구나 읽기, 로그인 본인만 작성, 본인 또는 관리자 삭제
    match /articleComments/{slug}/items/{itemId} {
      allow read:   if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // 소셜 — 방명록(주인만 삭제)
    match /guestbook/{ownerUid}/entries/{entryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == ownerUid;
    }

    // 소셜 — 1:1 DM (대화 당사자만)
    match /dm_threads/{threadId} {
      allow read, write: if request.auth != null && request.auth.uid in threadId.split('__');
      match /messages/{msgId} {
        allow read, write: if request.auth != null && request.auth.uid in threadId.split('__');
      }
    }

    // 글을 읽을 수 있는 사람인지 판단(댓글 권한에 재사용)
    function canReadPost(postId) {
      let p = get(/databases/$(database)/documents/feed/$(postId)).data;
      return p.visibility == 'public'
             || (request.auth != null && (request.auth.uid == p.uid || request.auth.uid in p.allowedUids));
    }

    // 타인의 좋아요 토글만 허용: 본인 uid 하나만 추가/제거 + likeCount 정확히 ±1(음수 금지).
    //  다른 사람 uid 를 배열에 넣거나 빼거나, likeCount 를 임의 값으로 바꾸는 것을 차단.
    function feedLikeToggleOnly() {
      let b = resource.data;
      let a = request.resource.data;
      let uid = request.auth.uid;
      return a.diff(b).affectedKeys().hasOnly(['likeCount', 'likedBy'])
             && a.likeCount >= 0
             && (
               // 좋아요 추가
               ( !(uid in b.likedBy)
                 && a.likedBy.hasAll(b.likedBy)
                 && a.likedBy.size() == b.likedBy.size() + 1
                 && (uid in a.likedBy)
                 && a.likeCount == b.likeCount + 1 )
               ||
               // 좋아요 취소
               ( (uid in b.likedBy)
                 && b.likedBy.hasAll(a.likedBy)
                 && a.likedBy.size() == b.likedBy.size() - 1
                 && !(uid in a.likedBy)
                 && a.likeCount == b.likeCount - 1 )
             );
    }

    // 타인의 댓글수 갱신: commentCount 만 정확히 ±1(음수 금지). 임의 값 설정 차단.
    //  ⚠️ 실제 댓글 작성 여부와 원자적으로 묶을 수 없어(서브컬렉션 별도 쓰기) 반복 ±1 조작은
    //     남아있음 → 정확한 집계는 후속(feed/{id}/likes·comments 파생) 단계 과제.
    function feedCommentCountNudge() {
      let b = resource.data;
      let a = request.resource.data;
      return a.diff(b).affectedKeys().hasOnly(['commentCount'])
             && a.commentCount >= 0
             && ( a.commentCount == b.get('commentCount', 0) + 1
                  || a.commentCount == b.get('commentCount', 0) - 1 );
    }

    // 04-4 작성자 일반 수정: 본문·공개범위·미디어만. status 는 published 유지(삭제글 수정·복원 차단),
    //  집계·작성자·작성일은 못 바꿈(허용 키에서 제외됨).
    function feedOwnerEdit() {
      let b = resource.data;
      let a = request.resource.data;
      return b.get('status', 'published') == 'published'
             && a.get('status', 'published') == 'published'
             && a.diff(b).affectedKeys().hasOnly(['text', 'visibility', 'allowedUids', 'mediaUrl', 'mediaType', 'updatedAt']);
    }

    // 04-4 작성자 소프트삭제: published→deleted 로만. status·deletedAt·updatedAt 외 변경 금지
    //  (본문·작성자·집계 동시 변조 차단). 이미 deleted 인 글 재삭제 차단.
    function feedOwnerSoftDelete() {
      let b = resource.data;
      let a = request.resource.data;
      return b.get('status', 'published') == 'published'
             && a.status == 'deleted'
             && a.diff(b).affectedKeys().hasOnly(['status', 'deletedAt', 'updatedAt']);
    }

    // 소셜 — 피드 (공개범위: public=전체 / 그 외=allowedUids 에 포함된 사람만)
    //  status: 미설정=published 로 해석(하위호환). deleted 공개글은 익명 조회에서 제외.
    match /feed/{postId} {
      allow read: if (resource.data.visibility == 'public'
                       && resource.data.get('status', 'published') != 'deleted')
                  || (request.auth != null && (request.auth.uid == resource.data.uid
                       || request.auth.uid in resource.data.allowedUids));
      // 작성: authorId=본인 uid 강제 + visibility 화이트리스트 + status=published + 집계값 0 시작
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.visibility in ['public', 'friends', 'groups']
                    && request.resource.data.get('status', 'published') == 'published'
                    && request.resource.data.likeCount == 0
                    && request.resource.data.likedBy.size() == 0
                    && request.resource.data.get('commentCount', 0) == 0;
      // 수정: 불변식(모든 경로) — authorId·작성일 변경 불가, visibility 화이트리스트,
      //  status 는 published/deleted 만, 집계값 음수 금지. 그 위에서:
      //  · 소유자: 일반수정(feedOwnerEdit) 또는 소프트삭제(feedOwnerSoftDelete)
      //  · 누구나(소유자 포함): 본인 좋아요 토글 또는 댓글수 ±1.
      allow update: if request.auth != null
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.visibility in ['public', 'friends', 'groups']
                    && request.resource.data.get('status', 'published') in ['published', 'deleted']
                    && request.resource.data.likeCount >= 0
                    && request.resource.data.get('commentCount', 0) >= 0
                    && (
                      feedLikeToggleOnly()
                      || feedCommentCountNudge()
                      || (request.auth.uid == resource.data.uid && (feedOwnerEdit() || feedOwnerSoftDelete()))
                    );
      // 하드삭제: 작성자만(관리자/정리용). 일반 UI 는 소프트삭제(status:deleted) 사용.
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

      // 댓글 — 글을 볼 수 있는 사람만 읽기/작성, 본인 또는 글주인이 삭제
      match /comments/{commentId} {
        allow read:   if canReadPost(postId);
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uid && canReadPost(postId);
        allow delete: if request.auth != null && (request.auth.uid == resource.data.uid
                       || request.auth.uid == get(/databases/$(database)/documents/feed/$(postId)).data.uid);
      }
    }

    // 알림 — 받는 사람만 읽기/정리. 관리자는 그대로(솜사탕·프리미엄 지급 알림 등), 일반 사용자는 '자기 이름으로'만 생성(익명 스팸·발신자 위조 차단)
    match /notifications/{uid}/items/{itemId} {
      allow read:           if request.auth != null && request.auth.uid == uid;
      allow create:         if request.auth != null && (
                               isAdmin() ||
                               (request.resource.data.fromUid == request.auth.uid && request.resource.data.fromUid != uid)
                             );
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // 코지홈 방문자 카운터(투데이/투탈) — pendingCandy/pendingPremium(관리자 재화·프리미엄 지급 폴백 경로)은 관리자만 값 변경 가능
    match /visits/{uid} {
      allow read: if true;
      allow create: if isAdmin() || (!('pendingCandy' in request.resource.data) && !('pendingPremium' in request.resource.data));
      allow update: if isAdmin() || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pendingCandy', 'pendingPremium']);
      match /days/{date} { allow read: if true; allow write: if true; }
    }

    // 건의사항 — 누구나 작성, 운영자 일일 디제스트용 읽기 허용(피드백이라 저민감), 수정/삭제는 관리자만
    match /suggestions/{id} {
      allow create: if true;
      allow read:   if true;
      allow update, delete: if isAdmin();
    }

    // 몽글로 동물도감 검수 상태 — 공개페이지가 승인목록을 읽어야 해서 읽기는 전체 공개, 쓰기는 관리자만
    match /animalReview/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 나만의 동물(유저 창작) — 공개 갤러리·프로필용. 누구나 읽기, 본인만 생성, 소유자 수정 또는 좋아요 필드만, 소유자·관리자 삭제
    match /animalCreations/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'likedBy'])
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // 나만의 동물 일일 생성 쿼터 — 본인만(엣지 함수가 본인 토큰으로 읽기/증가). 서버가 3회 제한 강제
    match /userAnimalQuota/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
