        {
            "parameters": {
                "jsCode": "const files = items.map(item => item.json.name);\nconst trendFiles = files.filter(name => name.startsWith('trend-') && name.endsWith('.md'));\nlet maxId = 0;\n\nif (trendFiles.length > 0) {\n  const ids = trendFiles.map(name => parseInt(name.replace('trend-', '').replace('.md', '')));\n  maxId = Math.max(...ids);\n}\n\nconst nextId = maxId > 0 ? maxId + 1 : 1;\nreturn { json: { nextId: nextId } };"
            },
            "id": "calc-next-id",
            "name": "Calculate Next ID",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                440,
                0
            ]
        },
        {
            "parameters": {
                "url": "https://news.hada.io/rss"
