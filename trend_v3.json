            "name": "Fetch TechCrunch",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                880,
                0
            ]
        },
        {
            "parameters": {
                "jsCode": "const geekNews = $('Fetch GeekNews').first().json.rss.channel.item || [];\nconst techCrunch = items[0].json.rss.channel.item || [];\n\nconst allNews = [...geekNews, ...techCrunch].slice(0, 20);\n\nconst newsText = allNews.map((item, index) => `${index + 1}. ${item.title} - ${item.link}`).join('\\n');\n\nreturn { json: { newsText: newsText, nextId: $('Calculate Next ID').first().json.nextId } };"
            },
            "id": "aggregate-news",
            "name": "Aggregate News",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1100,
